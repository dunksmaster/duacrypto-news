---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Analytics — DuaCrypto News";
---

<BaseLayout title={title} description="Internal analytics dashboard" lang="en" locale="en" noLargePreview>
  <section class="py-12">
    <div class="section-shell max-w-5xl">
      <h1 class="mb-2 text-4xl font-bold">Analytics</h1>
      <p class="mb-8 text-secondary">
        Views, likes, and affiliate clicks (last 30 days). Protect this route with
        <a href="https://developers.cloudflare.com/cloudflare-one/policies/access/" class="text-primary underline"
          >Cloudflare Access</a
        > on <code>/admin/*</code> and <code>/api/stats</code>.
      </p>
      <div id="stats-loading" class="text-secondary">Loading…</div>
      <div id="stats-error" class="hidden text-red-600"></div>
      <div id="stats-root" class="hidden space-y-10"></div>
    </div>
  </section>
  <script is:inline src="/js/admin-stats.js"></script>
</BaseLayout>
