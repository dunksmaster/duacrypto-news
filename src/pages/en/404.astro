---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t, localePath } from "../../i18n/ui";
import { getPublishedPostsForLocale, postHref, postSlug } from "../../lib/posts";

const locale = "en" as const;
const strings = t(locale);
const posts = await getPublishedPostsForLocale(locale);
---

<BaseLayout
  title={strings.notFoundTitle}
  description={strings.notFoundBody}
  lang="en"
  locale={locale}
  canonical={`${Astro.site}en/404/`}
>
  <section class="py-24 text-center" data-pagefind-body>
    <div class="section-shell">
      <h1 class="mb-4 text-5xl font-bold">{strings.notFoundTitle}</h1>
      <p class="mb-8 text-secondary">{strings.notFoundBody}</p>
      <a href={localePath("/", locale)} class="btn-primary">{strings.backHome}</a>
      {
        posts.length > 0 && (
          <div class="mt-12 text-left max-w-xl mx-auto">
            <h2 class="mb-4 text-xl font-bold">{strings.latestPosts}</h2>
            <ul class="space-y-2 text-secondary">
              {posts.slice(0, 5).map((post) => (
                <li>
                  <a href={postHref(postSlug(post.id), locale)} class="text-primary hover:underline">
                    {post.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
