---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import { getPublishedPostsForLocale, getPostsByTag } from "../../../lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPostsForLocale("en");
  const tags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) tags.add(tag);
  }
  return [...tags].map((tag) => ({ params: { tag } }));
}

const locale = "en" as const;

const { tag } = Astro.params;
if (!tag) return Astro.redirect("/en/404/");

const posts = await getPostsByTag(tag, locale);
---

<BaseLayout
  title={`#${tag} — DuaCrypto News`}
  description={`Posts tagged ${tag} on DuaCrypto News.`}
  lang="en"
  locale={locale}
  canonical={`${Astro.site}en/tags/${tag}/`}
>
  <section class="py-12" data-pagefind-body>
    <div class="section-shell">
      <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-primary">Tag</p>
      <h1 class="mb-8 text-4xl font-bold">#{tag}</h1>
      {
        posts.length === 0 ? (
          <p class="text-secondary">No posts with this tag.</p>
        ) : (
          <div class="feed-list">
            {posts.map((post) => (
              <PostCard post={post} locale={locale} />
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
