---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import { categories } from "../../../content.config";
import { getPostsByCategory } from "../../../lib/posts";
import { t, categoryLabel } from "../../../i18n/ui";

const locale = "en" as const;
const strings = t(locale);

export async function getStaticPaths() {
  return categories.map((category) => ({ params: { category } }));
}

const { category } = Astro.params;

if (!category || !categories.includes(category as (typeof categories)[number])) {
  return Astro.redirect("/en/404/");
}

const posts = await getPostsByCategory(category as (typeof categories)[number], locale);
const label = categoryLabel(category, locale);
---

<BaseLayout
  title={`${label} — DuaCrypto News`}
  description={`${label} articles from DuaCrypto News.`}
  lang="en"
  locale={locale}
  canonical={`${Astro.site}en/category/${category}/`}
>
  <section class="py-12" data-pagefind-body>
    <div class="section-shell">
      <h1 class="mb-8 text-4xl font-bold">{label}</h1>
      {
        posts.length === 0 ? (
          <p class="text-secondary">No posts in this category yet.</p>
        ) : (
          <div class="feed-list">
            {posts.map((post) => (
              <PostCard post={post} locale={locale} />
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
