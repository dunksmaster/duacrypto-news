---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import CategoryRows from "../../components/CategoryRows.astro";
import PopularPosts from "../../components/PopularPosts.astro";
import { getPublishedPostsForLocale } from "../../lib/posts";
import { t, localePath } from "../../i18n/ui";
import site from "../../data/site.json";

const locale = "en" as const;
const strings = t(locale);
const CATEGORY_LABELS = site.categoryLabels;
const NAV_CATEGORIES = site.navCategories;

const posts = await getPublishedPostsForLocale(locale);
const featured = posts[0];
const latest = posts.slice(1, 7);
---

<BaseLayout
  title="DuaCrypto News"
  description="Bitcoin and Web3 news for the Albanian diaspora and Balkans — in English."
  lang="en"
  locale={locale}
  canonical={`${Astro.site}en/`}
  showTrustBar={true}
>
  <section class="border-b border-border bg-surface py-16" data-pagefind-body>
    <div class="section-shell">
      <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-primary">DuaCrypto News</p>
      <h1 class="max-w-3xl text-4xl font-bold sm:text-5xl">{strings.heroTitle}</h1>
      <p class="mt-4 max-w-2xl text-lg text-secondary">{strings.heroSubtitle}</p>
    </div>
  </section>

  {
    featured && (
      <section class="py-12">
        <div class="section-shell">
          <h2 class="mb-6 text-2xl">{strings.featured}</h2>
          <PostCard post={featured} featured locale={locale} />
        </div>
      </section>
    )
  }

  <PopularPosts locale={locale} posts={posts} />

  <CategoryRows locale={locale} posts={posts} />

  <section class="pb-8">
    <div class="section-shell">
      <h2 class="mb-6 text-2xl">{strings.browseCategory}</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          NAV_CATEGORIES.map((category) => (
            <a
              href={localePath(`/category/${category}/`, locale)}
              class="rounded-lg border border-border bg-card p-5 transition hover:border-primary/40"
            >
              <span class="category-pill">{CATEGORY_LABELS[category]}</span>
              <p class="mt-3 text-sm text-secondary">
                {posts.filter((p) => p.data.category === category).length} {strings.postsCount}
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {
    latest.length > 0 && (
      <section class="pb-16">
        <div class="section-shell">
          <h2 class="mb-6 text-2xl">{strings.latestPosts}</h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {latest.map((post) => (
              <PostCard post={post} locale={locale} />
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
