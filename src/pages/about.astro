---
import BaseLayout from "../layouts/BaseLayout.astro";
import site from "../data/site.json";
const MAIN_SITE = site.mainSite;
---

<BaseLayout
  title="About DuaCrypto News"
  description="About the DuaCrypto News site — Bitcoin and Web3 stories from Albania and the Balkans."
>
  <section class="py-12">
    <div class="section-shell max-w-3xl">
      <h1 class="mb-6 text-4xl font-bold">About DuaCrypto News</h1>
      <div class="space-y-4 text-secondary [&_a]:text-primary [&_a]:underline">
        <p>
          DuaCrypto News is the editorial home for event recaps, guides, analysis, and community
          stories from <a href={MAIN_SITE}>DuaCrypto</a> — Albania's first Bitcoin and Web3
          community, founded in 2020.
        </p>
        <p>
          We publish practical education for newcomers, enterprise insights for corporate teams, and
          on-the-ground reporting from meetups and regional conferences across the Balkans.
        </p>
        <p>
          Want to collaborate or suggest a topic? Email
          <a href="mailto:usdc@duacrypto.com">usdc@duacrypto.com</a> or join our
          <a href="https://t.me/dua_crypto">Telegram community</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
