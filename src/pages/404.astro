---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" description="The page you requested could not be found.">
  <section class="py-24 text-center">
    <div class="section-shell">
      <h1 class="mb-4 text-5xl font-bold">404</h1>
      <p class="mb-8 text-secondary">That page doesn't exist.</p>
      <a href="/" class="btn-primary">Back to news home</a>
    </div>
  </section>
</BaseLayout>
