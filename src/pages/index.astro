---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getPublishedPosts } from "../lib/posts";
import site from "../data/site.json";
const CATEGORY_LABELS = site.categoryLabels;
const NAV_CATEGORIES = site.navCategories;
const SITE_DESCRIPTION = site.siteDescription;

const posts = await getPublishedPosts();
const featured = posts[0];
const latest = posts.slice(1);
---

<BaseLayout title="DuaCrypto News" description={SITE_DESCRIPTION}>
  <section class="border-b border-border bg-surface py-16">
    <div class="section-shell">
      <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-primary">DuaCrypto News</p>
      <h1 class="max-w-3xl text-4xl font-bold sm:text-5xl">
        Bitcoin &amp; Web3 from Albania and the Balkans
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-secondary">
        Event recaps, guides, analysis, and community stories from Albania's first crypto community.
      </p>
    </div>
  </section>

  {
    featured && (
      <section class="py-12">
        <div class="section-shell">
          <h2 class="mb-6 text-2xl">Featured</h2>
          <PostCard post={featured} featured />
        </div>
      </section>
    )
  }

  <section class="pb-8">
    <div class="section-shell">
      <h2 class="mb-6 text-2xl">Browse by category</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          NAV_CATEGORIES.map((category) => (
            <a
              href={`/category/${category}/`}
              class="rounded-lg border border-border bg-card p-5 transition hover:border-primary/40"
            >
              <span class="category-pill">{CATEGORY_LABELS[category]}</span>
              <p class="mt-3 text-sm text-secondary">
                {posts.filter((p) => p.data.category === category).length} posts
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="section-shell">
      <h2 class="mb-6 text-2xl">Latest posts</h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {latest.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
