---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import GeoBanner from "../components/GeoBanner.astro";
import TrustBar from "../components/TrustBar.astro";
import site from "../data/site.json";
import { organizationJsonLd } from "../lib/organization";
import type { Locale } from "../i18n/ui";

const SITE_NAME = site.siteName;
const SITE_DESCRIPTION = site.siteDescription;
const MAIN_SITE = site.mainSite;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  pubDate?: Date;
  author?: string;
  canonical?: string;
  lang?: string;
  locale?: Locale;
  hreflangAlternates?: { hreflang: string; href: string }[];
  jsonLdExtra?: Record<string, unknown>[];
  noLargePreview?: boolean;
  ogLocale?: string;
  ogLocaleAlternates?: string[];
  pagefindLang?: string;
  switchTarget?: { href: string; available: boolean; label?: string };
  oEmbedUrl?: string;
  oEmbedTitle?: string;
  mdAlternateUrl?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  image = "/img/duacrypto-logo.png",
  type = "website",
  canonical,
  lang = "en",
  locale = lang === "sq" ? "sq" : "en",
  hreflangAlternates = [],
  jsonLdExtra = [],
  noLargePreview = false,
  ogLocale = locale === "sq" ? "sq_AL" : "en_US",
  ogLocaleAlternates = locale === "sq" ? ["en_US"] : ["sq_AL"],
  pagefindLang,
  switchTarget,
  oEmbedUrl,
  oEmbedTitle,
  mdAlternateUrl,
} = Astro.props;

const pageTitle = title ? `${title} | ${SITE_NAME}` : SITE_NAME;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
const rssHref = locale === "en" ? "/en/rss.xml" : "/rss.xml";

const graph = [
  type === "website"
    ? {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: SITE_NAME,
        url: Astro.site,
        description,
        publisher: organizationJsonLd(),
      }
    : null,
  ...jsonLdExtra.map((node) => ({ "@context": "https://schema.org", ...node })),
].filter(Boolean);

const jsonLd = graph.length === 1 ? graph[0] : { "@context": "https://schema.org", "@graph": graph };
---

<!doctype html>
<html lang={lang} data-pagefind-filter={`lang:${pagefindLang ?? lang}`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline src="/theme-init.js"></script>
    <link rel="icon" href="/img/duacrypto-logo.png" type="image/png" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} RSS`} href={rssHref} />
    {hreflangAlternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    {
      oEmbedUrl && (
        <link
          rel="alternate"
          type="application/json+oembed"
          href={oEmbedUrl}
          title={oEmbedTitle ?? pageTitle}
        />
      )
    }
    {
      mdAlternateUrl && (
        <link rel="alternate" type="text/markdown" href={mdAlternateUrl} title={pageTitle} />
      )
    }
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {!noLargePreview && (
      <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    )}
    <meta property="og:type" content={type} />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map((alt) => (
      <meta property="og:locale:alternate" content={alt} />
    ))}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script defer src="/js/gtag-deferred.js"></script>
  </head>
  <body class="min-h-screen flex flex-col" data-pagefind-filter={`lang:${pagefindLang ?? lang}`}>
    <div id="reading-progress" aria-hidden="true"></div>
    <GeoBanner locale={locale} />
    <TrustBar locale={locale} />
    <Header locale={locale} switchTarget={switchTarget} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
    <script defer src="/js/engagement.js"></script>
    <script defer src="/js/reading-progress.js"></script>
  </body>
</html>
