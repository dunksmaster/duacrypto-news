---
import "../styles/global.css";
import type { Locale } from "../i18n/ui";

interface Props {
  title: string;
  description: string;
  image: string;
  canonical: string;
  locale: Locale;
  categoryLabel: string;
}

const { title, description, image, canonical, locale, categoryLabel } = Astro.props;
const readLabel = locale === "sq" ? "Lexo në DuaCrypto News →" : "Read on DuaCrypto News →";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={canonical} />
  </head>
  <body class="embed-body">
    <a href={canonical} class="embed-card" target="_top" rel="noopener">
      <img src={image} alt="" class="embed-image" width="1200" height="630" loading="lazy" />
      <div class="embed-content">
        <p class="embed-category">{categoryLabel}</p>
        <h1 class="embed-title">{title}</h1>
        <p class="embed-desc">{description}</p>
        <p class="embed-cta">{readLabel}</p>
      </div>
    </a>
  </body>
</html>

<style is:global>
  .embed-body {
    margin: 0;
    font-family: "Segoe UI", system-ui, sans-serif;
    background: #0f172a;
    color: #f8fafc;
  }
  .embed-card {
    display: block;
    max-width: 560px;
    margin: 0 auto;
    text-decoration: none;
    color: inherit;
    border: 1px solid #334155;
    border-radius: 12px;
    overflow: hidden;
    background: #1e293b;
  }
  .embed-image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1200 / 630;
    object-fit: cover;
  }
  .embed-content {
    padding: 1rem 1.25rem 1.25rem;
  }
  .embed-category {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #f7931a;
  }
  .embed-title {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
    line-height: 1.35;
    color: #fff;
  }
  .embed-desc {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #94a3b8;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .embed-cta {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 700;
    color: #f7931a;
  }
</style>
