---
import { getCollection, render } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import AffiliateDisclosure from "../components/AffiliateDisclosure.astro";
import NewsletterCTA from "../components/NewsletterCTA.astro";
import NewsletterInline from "../components/NewsletterInline.astro";
import AuthorChip from "../components/AuthorChip.astro";
import AuthorBox from "../components/AuthorBox.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import RequestTranslation from "../components/RequestTranslation.astro";
import ShareRow from "../components/ShareRow.astro";
import TableOfContents from "../components/TableOfContents.astro";
import PostNav from "../components/PostNav.astro";
import ZapButton from "../components/ZapButton.astro";
import NostrNote from "../components/NostrNote.astro";
import type { CollectionEntry } from "astro:content";
import site from "../data/site.json";
import { t, localePath, type Locale } from "../i18n/ui";
import {
  formatDate,
  postSlug,
  readingTime,
  getPublishedPosts,
  postHref,
  categoryHref,
  resolveOgImagePath,
  resolveHeroSrc,
  extractToc,
  getCategoryAdjacentPosts,
} from "../lib/posts";
import {
  buildHreflangAlternates,
  buildOgLocaleAlternates,
  findTranslationPartner,
  getPostLocale,
  switcherTarget,
} from "../lib/i18n";
import {
  organizationJsonLd,
  breadcrumbJsonLd,
  faqJsonLd,
  howToJsonLd,
  blogPostingJsonLd,
} from "../lib/organization";

interface Props {
  post: CollectionEntry<"posts">;
  locale: Locale;
}

const { post, locale } = Astro.props;
const strings = t(locale);
const { Content } = await render(post);
const slug = postSlug(post.id);
const minutes = readingTime(post.body ?? "");
const lang = getPostLocale(post);
const isAffiliate = post.data.postType === "affiliate";
const allPosts = await getPublishedPosts();
const related = allPosts
  .filter((p) => getPostLocale(p) === locale && p.id !== post.id && p.data.category === post.data.category)
  .slice(0, 3);

const base = Astro.site?.href ?? "https://news.duacrypto.com/";
const canonical = new URL(postHref(slug, locale), base).href;
const ogImagePath = resolveOgImagePath(post.data.image, slug);
const shareUrl = `${canonical}${canonical.includes("?") ? "&" : "?"}utm_source=share`;
const embedUrl = new URL(locale === "en" ? `/en/embed/${slug}/` : `/embed/${slug}/`, base).href;
const oEmbedUrl = `${base.replace(/\/$/, "")}/api/oembed?url=${encodeURIComponent(canonical)}`;
const categoryLabel = site.categoryLabels[post.data.category];

const hreflangAlternates = buildHreflangAlternates(post, allPosts, base);
const ogLocaleInfo = buildOgLocaleAlternates(post, allPosts);
const hasTranslation = Boolean(findTranslationPartner(post, allPosts));
const languageSwitch = switcherTarget(post, allPosts, locale);

const breadcrumbItems = [
  { name: strings.home, url: new URL(localePath("/", locale), base).href },
  {
    name: categoryLabel,
    url: new URL(categoryHref(post.data.category, locale), base).href,
  },
  { name: post.data.title, url: canonical },
];

const jsonLdExtra = [
  organizationJsonLd(),
  blogPostingJsonLd({
    title: post.data.title,
    description: post.data.description,
    canonicalUrl: canonical,
    ogImage: new URL(ogImagePath, Astro.site).href,
    pubDate: post.data.pubDate,
    updatedDate: post.data.updatedDate,
    lang,
  }),
  breadcrumbJsonLd(breadcrumbItems),
  ...(post.data.faq?.length ? [faqJsonLd(post.data.faq)!] : []),
  ...(post.data.howToSteps?.length
    ? [howToJsonLd(post.data.title, post.data.description, post.data.howToSteps)!]
    : []),
].filter(Boolean);

const updated = post.data.updatedDate ?? post.data.pubDate;
const mdMirror = `/md/posts/${slug}.md`;
const heroSrc = resolveHeroSrc(post.data.image, slug, post.data.heroStyle);
const toc = extractToc(post.body ?? "");
const { older: olderPost, newer: newerPost } = getCategoryAdjacentPosts(post, allPosts, locale);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={ogImagePath}
  type="article"
  pubDate={post.data.pubDate}
  author={post.data.author}
  canonical={canonical}
  oEmbedUrl={oEmbedUrl}
  oEmbedTitle={post.data.title}
  lang={lang}
  locale={locale}
  hreflangAlternates={hreflangAlternates}
  ogLocale={ogLocaleInfo.locale}
  ogLocaleAlternates={ogLocaleInfo.alternates}
  jsonLdExtra={jsonLdExtra}
  pagefindLang={lang}
  switchTarget={languageSwitch}
  mdAlternateUrl={new URL(mdMirror, Astro.site).href}
>
  <article class="py-12" data-pagefind-body>
    <div class="section-shell post-with-toc">
      {toc.length >= 4 && <TableOfContents items={toc} locale={locale} variant="sidebar" />}

      <div class="post-main">
      <Breadcrumbs
        items={[
          { label: strings.home, href: localePath("/", locale) },
          { label: categoryLabel, href: categoryHref(post.data.category, locale) },
          { label: post.data.title },
        ]}
      />

      <div class="mb-4 flex flex-wrap items-center gap-2 meta-text">
        <a href={categoryHref(post.data.category, locale)} class="category-pill">
          {categoryLabel}
        </a>
        {post.data.aiGenerated && <span>AI-assisted</span>}
        <span aria-hidden="true">·</span>
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, locale)}</time>
        <span aria-hidden="true">·</span>
        <span>{minutes} {strings.minRead}</span>
        {
          updated.getTime() !== post.data.pubDate.getTime() && (
            <>
              <span aria-hidden="true">·</span>
              <span>{strings.updated} {formatDate(updated, locale)}</span>
            </>
          )
        }
        <span class="hidden inline-flex flex-wrap items-center gap-2" id="engagement-stats" data-slug={slug}>
          <span class="engagement-stat hidden" data-views-stat title="Views">👁 <span data-views>0</span></span>
          <span class="engagement-stat hidden" data-likes-stat>
            <button type="button" class="engagement-like" data-like-btn aria-pressed="false">
              🧡 <span data-likes>0</span>
            </button>
          </span>
        </span>
      </div>

      <h1 class="mb-3 text-4xl font-bold leading-tight">{post.data.title}</h1>
      <p class="mb-4 text-lg text-dark leading-relaxed">{post.data.description}</p>

      <AuthorChip locale={locale} />

      {isAffiliate && <AffiliateDisclosure lang={lang} compact />}

      {
        heroSrc && (
          <img
            src={heroSrc}
            alt={post.data.targetKeyword ?? post.data.title}
            width="1200"
            height="675"
            class="post-hero mb-8 max-h-[240px] w-full rounded-xl border border-border object-cover sm:max-h-[380px]"
            loading="eager"
          />
        )
      }

      {toc.length >= 4 && <TableOfContents items={toc} locale={locale} variant="mobile" />}

      {
        post.data.directAnswer && (
          <div class="direct-answer mb-8 rounded-lg px-4 py-3 text-dark leading-relaxed">
            <p class="m-0 font-semibold text-sm meta-text mb-1">{strings.directAnswerLabel}</p>
            <p class="m-0">{post.data.directAnswer}</p>
          </div>
        )
      }

      <div class="post-prose space-y-4">
        <Content />
      </div>

      <NewsletterInline locale={locale} />

      <ShareRow
        locale={locale}
        shareUrl={shareUrl}
        shareTitle={post.data.title}
        embedUrl={embedUrl}
        embedTitle={post.data.title}
      />
      <NostrNote locale={locale} slug={slug} />

      {
        post.data.faq && post.data.faq.length > 0 && (
          <section class="mt-10 border-t border-border pt-8" id="faq">
            <h2 class="mb-4 text-2xl font-bold">{strings.faqTitle}</h2>
            <div class="space-y-4">
              {post.data.faq.map((item) => (
                <details class="rounded-lg border border-border bg-surface px-4 py-3">
                  <summary class="cursor-pointer font-semibold">{item.question}</summary>
                  <p class="mt-2 mb-0 text-dark leading-relaxed">{item.answer}</p>
                </details>
              ))}
            </div>
          </section>
        )
      }

      {isAffiliate && <NewsletterCTA lang={lang} />}

      <PostNav locale={locale} older={olderPost} newer={newerPost} />

      <AuthorBox locale={locale} />

      {
        post.data.tags.length > 0 && (
          <div class="mt-10 flex flex-wrap gap-2 border-t border-border pt-6">
            {post.data.tags.map((tag) => (
              <a
                href={localePath(`/tags/${tag}/`, locale)}
                class="rounded-full bg-surface px-3 py-1 text-sm text-link no-underline hover:underline"
              >
                #{tag}
              </a>
            ))}
          </div>
        )
      }

      {!hasTranslation && (
        <RequestTranslation
          locale={locale}
          postSlug={slug}
          translationKey={post.data.translationKey ?? slug}
          postTitle={post.data.title}
        />
      )}

      <div class="mt-8 border-t border-border pt-6">
        <ZapButton locale={locale} postTitle={post.data.title} />
      </div>
      </div>
    </div>
  </article>

  {
    related.length > 0 && (
      <section class="border-t border-border bg-surface py-12">
        <div class="section-shell">
          <h2 class="mb-6 text-2xl">{strings.relatedPosts}</h2>
          <div class="grid gap-6 md:grid-cols-3">
            {related.map((item) => (
              <PostCard post={item} locale={locale} />
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .engagement-stat,
  .engagement-like {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-secondary);
  }
  .engagement-like {
    cursor: pointer;
    font: inherit;
    border: 0;
    background: transparent;
    padding: 0;
    color: inherit;
  }
  .engagement-like:hover {
    color: var(--color-primary);
  }
  .engagement-like.engagement-liked {
    border-color: var(--color-primary);
    color: var(--color-dark);
  }
  [data-card-views][hidden] {
    display: none;
  }
  .post-hero {
    max-height: 240px;
  }
  @media (min-width: 640px) {
    .post-hero {
      max-height: 380px;
    }
  }
</style>
