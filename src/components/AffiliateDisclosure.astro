---
interface Props {
  lang?: "en" | "sq";
  compact?: boolean;
}

const { lang = "en", compact = false } = Astro.props;

const copy =
  lang === "sq"
    ? {
        line: "Ky artikull përmban lidhje bashkëpunimi —",
        link: "si funksionon",
      }
    : {
        line: "This article contains affiliate links —",
        link: "how it works",
      };
---

{
  compact ? (
    <p class="affiliate-disclosure--compact" role="note">
      {copy.line}{" "}
      <a href={lang === "sq" ? "/about/" : "/en/about/"} class="text-link">
        {copy.link}
      </a>
      .
    </p>
  ) : (
    <aside
      class="affiliate-disclosure mb-8 rounded-lg border border-border bg-surface px-4 py-3 text-sm leading-relaxed"
      role="note"
    >
      <p class="mb-1 font-semibold text-dark">{lang === "sq" ? "Zbulim bashkëpunimi" : "Affiliate disclosure"}</p>
      <p class="m-0 text-dark">
        {
          lang === "sq"
            ? "Ky artikull përmban lidhje bashkëpunimi. Nëse blini përmes tyre, DuaCrypto mund të marrë komision pa kosto shtesë për ju."
            : "This article contains affiliate links. DuaCrypto may earn a commission at no extra cost to you."
        }
      </p>
    </aside>
  )
}
