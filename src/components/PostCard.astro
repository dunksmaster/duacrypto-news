---
import type { CollectionEntry } from "astro:content";
import site from "../data/site.json";
import { formatDate, postHref, categoryHref, tagHref } from "../lib/posts";
import type { Locale } from "../i18n/ui";

interface Props {
  post: CollectionEntry<"posts">;
  featured?: boolean;
  locale?: Locale;
}

const { post, featured = false, locale = "sq" } = Astro.props;
const slug = post.id.replace(/\.mdx?$/, "");
const CATEGORY_LABELS = site.categoryLabels;
---

<article class:list={["post-card h-full", { "md:flex-row md:items-start md:gap-6": featured }]}>
  <div class="flex-1">
    <div class="mb-3 flex flex-wrap items-center gap-2">
      <a href={categoryHref(post.data.category, locale)} class="category-pill">
        {CATEGORY_LABELS[post.data.category]}
      </a>
      {post.data.aiGenerated && (
        <span class="text-xs text-secondary">AI-assisted</span>
      )}
    </div>
    <h2 class:list={["mb-2", featured ? "text-3xl" : "text-xl"]}>
      <a href={postHref(slug, locale)} class="hover:text-primary">{post.data.title}</a>
    </h2>
    <p class="mb-4 text-secondary">{post.data.description}</p>
    <div class="mt-auto flex flex-wrap items-center gap-3 text-sm text-secondary">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, locale)}</time>
      <span>·</span>
      <span>{post.data.author}</span>
    </div>
    {post.data.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {post.data.tags.map((tag) => (
          <a href={tagHref(tag, locale)} class="text-xs text-primary hover:underline">#{tag}</a>
        ))}
      </div>
    )}
  </div>
</article>
