---
import type { CollectionEntry } from "astro:content";
import {
  formatTickerDate,
  postHref,
  postSlug,
  readingTime,
  resolveHeroSrc,
  categoryHref,
} from "../lib/posts";
import { categoryLabel, t, type Locale } from "../i18n/ui";

interface Props {
  post: CollectionEntry<"posts">;
  featured?: boolean;
  locale?: Locale;
}

const { post, featured = false, locale = "sq" } = Astro.props;
const strings = t(locale);
const slug = postSlug(post.id);
const catLabel = categoryLabel(post.data.category, locale);
const thumb = resolveHeroSrc(post.data.image, slug, post.data.heroStyle);
const minutes = readingTime(post.body ?? "");
const tickerDate = formatTickerDate(post.data.pubDate, locale);
const href = postHref(slug, locale);
---

{
  featured ? (
    <article class="feed-featured">
      <p class="meta-mono feed-featured__meta">
        <a href={categoryHref(post.data.category, locale)} class="feed-meta-cat">
          {catLabel}
        </a>
        <span class="feed-meta-sep" aria-hidden="true">///</span>
        <time datetime={post.data.pubDate.toISOString()}>{tickerDate}</time>
        <span class="feed-meta-sep" aria-hidden="true">///</span>
        <span>{minutes} MIN</span>
        <span class="post-card-views" data-card-views={slug} hidden />
      </p>
      <h2 class="feed-featured__title">
        <a href={href} class="text-link no-underline hover:underline">{post.data.title}</a>
      </h2>
      <p class="feed-featured__dek">{post.data.description}</p>
      <div class="feed-featured__actions">
        <a href={href} class="feed-featured__cta">{strings.readGuideCta}</a>
        <p class="meta-mono feed-featured__stats">
          <time datetime={post.data.pubDate.toISOString()}>{tickerDate}</time>
          <span class="feed-meta-sep" aria-hidden="true">///</span>
          <span>{minutes} MIN</span>
          <span class="post-card-views" data-card-views={slug} hidden />
        </p>
      </div>
      {
        thumb && (
          <a href={href} class="feed-featured__media" tabindex="-1" aria-hidden="true">
            <img src={thumb} alt="" width="640" height="360" class="feed-featured__img" loading="lazy" />
          </a>
        )
      }
    </article>
  ) : (
    <article class="feed-row">
      <div class="feed-row__body">
        <h2 class="feed-row__title">
          <a href={href} class="text-link no-underline hover:underline">{post.data.title}</a>
        </h2>
        <p class="meta-mono feed-row__meta">
          <a href={categoryHref(post.data.category, locale)} class="feed-meta-cat">
            {catLabel}
          </a>
          <span class="feed-meta-sep" aria-hidden="true">///</span>
          <time datetime={post.data.pubDate.toISOString()}>{tickerDate}</time>
          <span class="feed-meta-sep" aria-hidden="true">///</span>
          <span>{minutes} MIN</span>
          <span class="post-card-views" data-card-views={slug} hidden />
        </p>
      </div>
      {
        thumb && (
          <a href={href} class="feed-row__thumb" tabindex="-1" aria-hidden="true">
            <img src={thumb} alt="" width="64" height="48" loading="lazy" />
          </a>
        )
      }
    </article>
  )
}

<style>
  .feed-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--hairline, var(--color-border));
  }

  .feed-row__body {
    min-width: 0;
    flex: 1;
  }

  .feed-row__title {
    margin: 0 0 0.4rem;
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .feed-row__title a {
    color: var(--ink, var(--color-dark));
  }

  .feed-row__title a:hover {
    color: var(--cyan, var(--color-link));
  }

  .feed-row__meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }

  .feed-meta-cat {
    color: var(--color-link, #045962);
    font-weight: 700;
    text-decoration: none;
  }

  .feed-meta-cat:hover {
    color: var(--color-primary-dark, #034652);
    text-decoration: underline;
  }

  .feed-meta-sep {
    color: var(--hairline, var(--color-border));
    font-weight: 400;
  }

  .feed-row__thumb {
    flex: 0 0 auto;
    width: 64px;
    height: 48px;
    overflow: hidden;
    border-radius: 4px;
    text-decoration: none;
  }

  .feed-row__thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .feed-featured {
    padding: 0.5rem 0 1.25rem;
    border-bottom: 1px solid var(--hairline, var(--color-border));
  }

  .feed-featured__meta {
    margin: 0 0 0.75rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }

  .feed-featured__title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.9rem, 4.5vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    text-wrap: balance;
  }

  .feed-featured__title a {
    color: var(--ink, var(--color-dark));
  }

  .feed-featured__title a:hover {
    color: var(--cyan, var(--color-link));
  }

  .feed-featured__dek {
    margin: 0 0 1rem;
    max-width: 40rem;
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--ink-2, var(--color-secondary));
  }

  .feed-featured__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 0.25rem;
    margin-bottom: 1rem;
  }

  .feed-featured__cta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--btc-ink);
    background: var(--btc);
    padding: 12px 22px;
    border-radius: 9px;
    text-decoration: none;
    box-shadow: 0 1px 0 color-mix(in srgb, var(--btc-dark) 40%, transparent);
  }

  .feed-featured__cta:hover {
    background: var(--btc-dark);
    color: var(--btc-ink);
    text-decoration: none;
  }

  .feed-featured__stats {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-text-muted);
  }

  .feed-featured__media {
    display: block;
    max-width: 28rem;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
  }

  .feed-featured__img {
    display: block;
    width: 100%;
    max-height: 380px;
    object-fit: cover;
  }

  .post-card-views[hidden] {
    display: none;
  }
</style>
