---
import type { CollectionEntry } from "astro:content";
import site from "../data/site.json";
import { formatDate, postHref, tagHref, postSlug, readingTime, resolveOgImagePath } from "../lib/posts";
import type { Locale } from "../i18n/ui";

interface Props {
  post: CollectionEntry<"posts">;
  featured?: boolean;
  locale?: Locale;
}

const { post, featured = false, locale = "sq" } = Astro.props;
const slug = postSlug(post.id);
const CATEGORY_LABELS = site.categoryLabels;
const imagePath = resolveOgImagePath(post.data.image, slug);
const minutes = readingTime(post.body ?? "");
---

<article class:list={["post-card", { "post-card--featured": featured }]}>
  <a href={postHref(slug, locale)} class="post-card-media" tabindex="-1" aria-hidden="true">
    <img
      src={imagePath}
      alt=""
      width="640"
      height="360"
      class="post-card-image"
      loading="lazy"
    />
    <span class="post-card-category">{CATEGORY_LABELS[post.data.category]}</span>
  </a>
  <div class="post-card-body">
    <h2 class:list={["post-card-title", { "post-card-title--featured": featured }]}>
      <a href={postHref(slug, locale)} class="text-link no-underline hover:underline">{post.data.title}</a>
    </h2>
    <p class="post-card-desc">{post.data.description}</p>
    <div class="post-card-meta meta-text">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, locale)}</time>
      <span aria-hidden="true">·</span>
      <span>{minutes} min</span>
      <span class="post-card-views" data-card-views={slug} hidden></span>
    </div>
    {
      post.data.tags.length > 0 && (
        <div class="post-card-tags">
          {post.data.tags.slice(0, 3).map((tag) => (
            <a href={tagHref(tag, locale)} class="text-link text-xs no-underline hover:underline">
              #{tag}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-card);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .post-card:hover {
    border-color: color-mix(in srgb, var(--color-primary) 40%, transparent);
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }

  .post-card--featured {
    flex-direction: row;
    align-items: stretch;
  }

  .post-card--featured .post-card-media {
    flex: 0 0 min(100%, 20rem);
  }

  .post-card-media {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    text-decoration: none;
  }

  .post-card-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-card-category {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    border-radius: 9999px;
    background-color: color-mix(in srgb, var(--color-page) 88%, transparent);
    padding: 0.25rem 0.75rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-link);
  }

  .post-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1rem 1.25rem 1.25rem;
  }

  .post-card-title {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-title--featured {
    font-size: 1.75rem;
  }

  .post-card-title a {
    color: var(--color-dark);
  }

  .post-card-title a:hover {
    color: var(--color-link);
  }

  .post-card-desc {
    margin: 0 0 0.75rem;
    flex: 1;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .post-card-views[hidden] {
    display: none;
  }

  @media (min-width: 768px) {
    .post-card--featured .post-card-media {
      flex-basis: 42%;
    }
  }
</style>
