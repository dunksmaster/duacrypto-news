---
import author from "../data/author.json";
import { localePath, t, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
const profileHref = localePath(author.profileUrl, locale);
---

<section class="author-box mt-10 rounded-xl border border-border bg-surface p-5">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
    <img
      src={author.photo}
      alt={author.displayName}
      width="80"
      height="80"
      class="h-20 w-20 shrink-0 rounded-full border border-border object-cover"
      loading="lazy"
    />
    <div>
      <h2 class="mb-1 text-lg font-bold">{strings.aboutAuthor} {author.displayName}</h2>
      <p class="mb-2 text-sm text-secondary">{author.role[locale]}</p>
      <p class="mb-3 text-sm leading-relaxed text-dark">{author.bio[locale]}</p>
      <div class="flex flex-wrap gap-3 text-sm">
        <a href={author.telegram} class="text-primary hover:underline" rel="noopener noreferrer">Telegram</a>
        <a href={author.x} class="text-primary hover:underline" rel="noopener noreferrer">X</a>
        <a href={profileHref} class="text-primary hover:underline">{strings.aboutAuthorPage}</a>
      </div>
    </div>
  </div>
</section>
