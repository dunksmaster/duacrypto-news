---
import site from "../data/site.json";
import { t, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "sq" } = Astro.props;
const strings = t(locale);
---

<div class="trust-bar">
  <div class="section-shell trust-bar__inner">
    <p class="meta-mono trust-bar__ticker">
      <span>{strings.trustLead}</span>
      <span class="trust-bar__sep" aria-hidden="true">///</span>
      <span>
        <strong class="trust-bar__count">{site.telegramMembers}</strong>
        {strings.trustTelegramShort}
      </span>
      <span class="trust-bar__sep" aria-hidden="true">///</span>
      <span>{strings.trustSince} {site.foundingYear}</span>
    </p>
    <a
      href={site.telegramUrl}
      class="trust-bar__cta"
      rel="noopener noreferrer"
    >
      {strings.trustJoinShort}
    </a>
  </div>
</div>

<style>
  .trust-bar {
    border-bottom: 1px solid var(--hairline, var(--color-border));
    background: var(--surface, var(--color-surface));
  }

  .trust-bar__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem 1.25rem;
    padding-block: 0.65rem;
  }

  .trust-bar__ticker {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    color: var(--ink-2, var(--color-secondary));
    text-align: center;
  }

  .trust-bar__count {
    color: var(--ink, var(--color-dark));
    font-weight: 700;
  }

  .trust-bar__sep {
    color: var(--hairline, var(--color-border));
    font-weight: 400;
  }

  .trust-bar__cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.35rem 0.9rem;
    border-radius: 0.375rem;
    border: 1px solid var(--cyan, var(--color-link));
    background: transparent;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-link);
    text-decoration: none;
    transition: background-color 0.2s, color 0.2s;
  }

  .trust-bar__cta:hover {
    background: color-mix(in srgb, var(--cyan, var(--color-link)) 10%, transparent);
    color: var(--color-link);
    text-decoration: none;
  }
</style>
