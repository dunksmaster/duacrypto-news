---
import site from "../data/site.json";
import { t, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "sq" } = Astro.props;
const strings = t(locale);
---

<div class="trust-bar border-b border-border bg-card text-sm text-secondary">
  <div class="section-shell flex flex-wrap items-center justify-center gap-x-4 gap-y-2 py-2.5 text-center">
    <span>
      <strong class="text-dark">{site.telegramMembers}</strong>
      {strings.trustTelegramMembers}
    </span>
    <span aria-hidden="true">·</span>
    <span>{strings.trustSince} {site.foundingYear}</span>
    <span aria-hidden="true">·</span>
    <a href={site.telegramUrl} class="text-primary font-semibold hover:underline" rel="noopener noreferrer">
      {strings.trustJoinTelegram}
    </a>
  </div>
</div>
