---
import site from "../data/site.json";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { t, localePath, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
  switchTarget?: { href: string; available: boolean; label?: string };
}

const { locale = "sq", switchTarget } = Astro.props;
const strings = t(locale);
const { pathname } = Astro.url;
const MAIN_SITE = site.mainSite;
const prefix = locale === "en" ? "/en" : "";

const nav = [
  { href: localePath("/", locale), label: strings.home, match: pathname === prefix || pathname === `${prefix}/` },
  { href: localePath("/category/news/", locale), label: strings.news, match: pathname.includes("/category/news") },
  { href: localePath("/category/analysis/", locale), label: strings.analysis, match: pathname.includes("/category/analysis") },
  { href: localePath("/category/guides/", locale), label: strings.guides, match: pathname.includes("/category/guides") },
  { href: localePath("/category/community/", locale), label: strings.community, match: pathname.includes("/category/community") },
  { href: localePath("/search/", locale), label: strings.search, match: pathname.includes("/search") },
  { href: localePath("/about/", locale), label: strings.about, match: pathname.includes("/about") },
];
---

<header class="site-header sticky top-0 z-50 border-b border-border">
  <div class="section-shell site-header__shell">
    <div class="site-header__bar">
      <a href={localePath("/", locale)} class="site-header__brand" aria-label="DuaCrypto News home">
        <img
          src="/img/duacrypto-logo.png"
          alt="DuaCrypto"
          width="379"
          height="378"
          class="h-10 w-auto"
        />
        <span class="site-header__wordmark hidden sm:inline">News<br />Terminal</span>
      </a>

      <button
        id="nav-toggle"
        type="button"
        class="site-header__toggle"
        aria-expanded="false"
        aria-controls="nav-menu"
        title="Toggle navigation"
      >
        <span class="text-xl" aria-hidden="true">☰</span>
      </button>
    </div>

    <nav id="nav-menu" class="site-header__nav">
      <div class="site-header__nav-links">
        {nav.map((item) => (
          <a href={item.href} class:list={["nav-link", { "nav-link-active": item.match }]}>
            {item.label}
          </a>
        ))}
        <a href={MAIN_SITE} class="nav-link">{strings.mainSite}</a>
      </div>

      <div class="site-header__nav-actions">
        <LanguageSwitcher locale={locale} switchTarget={switchTarget} />
        <button
          type="button"
          data-theme-toggle
          class="theme-toggle"
          aria-pressed="false"
          aria-label="Switch theme"
        >
          <span data-theme-icon>◐</span>
        </button>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");

  function setMenuOpen(open: boolean) {
    const isDesktop = window.matchMedia("(min-width: 1024px)").matches;
    if (isDesktop) return;

    menu?.classList.toggle("is-open", open);
    menu?.setAttribute("aria-hidden", String(!open));
    toggle?.setAttribute("aria-expanded", String(open));
  }

  function syncNavState() {
    const isDesktop = window.matchMedia("(min-width: 1024px)").matches;
    if (isDesktop) {
      menu?.classList.remove("is-open");
      menu?.setAttribute("aria-hidden", "false");
      toggle?.setAttribute("aria-expanded", "false");
      return;
    }

    const open = menu?.classList.contains("is-open") ?? false;
    menu?.setAttribute("aria-hidden", String(!open));
    toggle?.setAttribute("aria-expanded", String(open));
  }

  syncNavState();

  toggle?.addEventListener("click", () => {
    const open = !menu?.classList.contains("is-open");
    setMenuOpen(open);
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setMenuOpen(false));
  });

  window.matchMedia("(min-width: 1024px)").addEventListener("change", () => {
    syncNavState();
  });

  const themeBtn = document.querySelector("[data-theme-toggle]");
  const icon = document.querySelector("[data-theme-icon]");
  const root = document.documentElement;

  function applyTheme(theme: "light" | "dark") {
    const isDark = theme === "dark";
    root.classList.toggle("dark", isDark);
    root.setAttribute("data-theme", theme);
    root.style.colorScheme = theme;
    themeBtn?.setAttribute("aria-pressed", String(isDark));
    themeBtn?.setAttribute(
      "aria-label",
      isDark ? "Switch to light mode" : "Switch to dark mode",
    );
    if (icon) icon.textContent = isDark ? "☀" : "◐";
    localStorage.setItem("duacrypto-theme", theme);
  }

  const stored = localStorage.getItem("duacrypto-theme");
  const initial =
    stored === "dark" || stored === "light"
      ? stored
      : window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
  applyTheme(initial);

  themeBtn?.addEventListener("click", () => {
    const next = root.classList.contains("dark") ? "light" : "dark";
    applyTheme(next);
  });
</script>

<style>
  .site-header {
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .site-header__shell {
    position: relative;
  }

  .site-header__bar {
    display: flex;
    height: 68px;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-header__brand {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .site-header__wordmark {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border-left: 1px solid var(--color-border);
    padding-left: 10px;
    line-height: 1.3;
  }

  .site-header__toggle {
    display: inline-flex;
    min-height: 2.75rem;
    min-width: 2.75rem;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 0.375rem;
    padding: 0.5rem;
    color: var(--color-dark);
    background: transparent;
    cursor: pointer;
  }

  .site-header__nav {
    display: none;
    flex-direction: column;
    gap: 0.75rem;
    border-top: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--surface) 96%, transparent);
    padding: 0.75rem 0 1rem;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .site-header__nav.is-open {
    display: flex;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 60;
    box-shadow: 0 12px 24px color-mix(in srgb, var(--ink) 8%, transparent);
  }

  .site-header .nav-link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    white-space: nowrap;
  }

  .site-header__nav-links {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.25rem;
  }

  .site-header__nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 0.25rem;
  }

  @media (min-width: 1024px) {
    .site-header__shell {
      display: flex;
      height: 68px;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .site-header__bar {
      height: auto;
      flex-shrink: 0;
    }

    .site-header__toggle {
      display: none;
    }

    .site-header__nav,
    .site-header__nav.is-open {
      display: flex;
      position: static;
      flex: 1;
      flex-direction: row;
      align-items: center;
      justify-content: flex-end;
      gap: 1.5rem;
      border-top: 0;
      background: transparent;
      padding: 0;
      box-shadow: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }

    .site-header__nav-links {
      flex-direction: row;
      align-items: center;
      gap: 1.25rem;
      margin-left: auto;
    }

    .site-header__nav-actions {
      margin-left: 1.5rem;
      padding-top: 0;
    }

    .site-header .nav-link {
      padding-block: 1.5rem;
    }
  }
</style>
