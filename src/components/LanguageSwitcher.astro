---
import type { Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
  switchTarget?: { href: string; available: boolean; label?: string };
}

const { locale, switchTarget } = Astro.props;
const pathname = Astro.url.pathname;

let sqHref = locale === "sq" ? pathname : switchTarget?.available ? switchTarget.href : "/";
let enHref = locale === "en" ? pathname : switchTarget?.available ? switchTarget.href : "/en/";

if (switchTarget && !switchTarget.available && locale === "sq") {
  enHref = switchTarget.href;
}
---

<div class="flex items-center gap-1 text-sm">
  <a
    href={sqHref}
    class:list={["lang-switch", { "lang-switch-active": locale === "sq" }]}
    aria-current={locale === "sq" ? "page" : undefined}
  >
    SQ
  </a>
  <span class="text-secondary" aria-hidden="true">|</span>
  <a
    href={enHref}
    class:list={["lang-switch", { "lang-switch-active": locale === "en" }]}
    aria-current={locale === "en" ? "page" : undefined}
    title={switchTarget?.label}
  >
    EN
  </a>
</div>

<style>
  .lang-switch {
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-weight: 600;
    color: var(--color-secondary);
    text-decoration: none;
  }
  .lang-switch:hover {
    color: var(--color-primary);
  }
  .lang-switch-active {
    color: var(--color-dark);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
</style>
