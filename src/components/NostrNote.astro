---
import nostrEvents from "../data/nostr-events.json";
import site from "../data/site.json";
import { t, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
  slug: string;
}

const { locale, slug } = Astro.props;
const strings = t(locale);
const eventId = (nostrEvents as Record<string, string>)[slug];
const npub = site.nostrPublicKey?.trim();
---

{
  (eventId || npub) && (
    <section class="mt-8 border-t border-border pt-6">
      <h2 class="mb-3 text-lg font-bold">{strings.nostrTitle}</h2>
      <p class="mb-3 text-sm text-secondary">{strings.nostrHint}</p>
      <div class="flex flex-wrap gap-3 text-sm">
        {
          eventId && (
            <a
              href={`https://nostr.band/${eventId}`}
              class="text-primary underline"
              rel="noopener noreferrer"
              target="_blank"
            >
              {strings.nostrViewNote}
            </a>
          )
        }
        {
          npub && (
            <a
              href={`https://primal.net/${npub}`}
              class="text-primary underline"
              rel="noopener noreferrer"
              target="_blank"
            >
              {strings.nostrFollow}
            </a>
          )
        }
      </div>
    </section>
  )
}
