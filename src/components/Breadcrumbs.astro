---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6 text-sm text-secondary">
  <ol class="flex flex-wrap items-center gap-1">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1">
          {i > 0 && <span aria-hidden="true">/</span>}
          {item.href ? (
            <a href={item.href} class="hover:text-primary hover:underline">
              {item.label}
            </a>
          ) : (
            <span class="text-dark">{item.label}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
