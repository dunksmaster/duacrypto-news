---
import type { Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
  shareUrl: string;
  shareTitle: string;
  embedUrl?: string;
  embedTitle?: string;
  compact?: boolean;
  includePopover?: boolean;
}

const { locale, shareUrl, shareTitle, embedUrl, embedTitle, compact = false, includePopover = true } = Astro.props;
const encodedUrl = encodeURIComponent(shareUrl);
const encodedTitle = encodeURIComponent(shareTitle);
const iframeCode = embedUrl
  ? `<iframe src="${embedUrl}" width="100%" height="360" frameborder="0" loading="lazy" title="${(embedTitle ?? shareTitle).replace(/"/g, "&quot;")}"></iframe>`
  : "";

const links = [
  {
    id: "telegram",
    label: "Telegram",
    href: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`,
  },
  {
    id: "whatsapp",
    label: "WhatsApp",
    href: `https://wa.me/?text=${encodedTitle}%20${encodedUrl}`,
  },
  {
    id: "x",
    label: "X",
    href: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
  },
];
---

<div class:list={["share-row", compact && "share-row--compact"]} data-share-url={shareUrl} data-embed-code={iframeCode || undefined}>
  {!compact && <span class="share-row-label">{locale === "sq" ? "Ndaj" : "Share"}</span>}
  <div class="share-row-buttons">
    {
      links.map((link) => (
        <a
          class="share-btn"
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          data-share={link.id}
          title={link.label}
        >
          {compact ? (link.id === "telegram" ? "TG" : link.id === "whatsapp" ? "WA" : "X") : link.label}
        </a>
      ))
    }
    <button type="button" class="share-btn" data-copy-link title={locale === "sq" ? "Kopjo linkun" : "Copy link"}>
      {compact ? "🔗" : locale === "sq" ? "Kopjo linkun" : "Copy link"}
    </button>
    {
      embedUrl && includePopover && (
        <button type="button" class="share-btn share-btn-embed" data-embed-open aria-haspopup="dialog" title={locale === "sq" ? "Embed" : "Embed"}>
          {compact ? "</>" : `</> ${locale === "sq" ? "Embed" : "Embed"}`}
        </button>
      )
    }
    <button type="button" class="share-btn share-btn-native hidden" data-native-share>
      {locale === "sq" ? "Ndaj…" : "Share…"}
    </button>
  </div>
</div>

{
  embedUrl && includePopover && (
    <div class="embed-popover hidden" id="embed-popover" role="dialog" aria-modal="true" aria-labelledby="embed-popover-title">
      <div class="embed-popover-backdrop" data-embed-close />
      <div class="embed-popover-panel">
        <h3 id="embed-popover-title" class="embed-popover-title">
          {locale === "sq" ? "Kodi i embed" : "Embed code"}
        </h3>
        <p class="embed-popover-hint">
          {
            locale === "sq"
              ? "Vendose këtë iframe në blogun ose faqen tënde."
              : "Paste this iframe on your blog or site."
          }
        </p>
        <textarea class="embed-popover-code" readonly rows="3" aria-label={locale === "sq" ? "Kodi i embed" : "Embed code"}>{iframeCode}</textarea>
        <div class="embed-popover-actions">
          <button type="button" class="btn-primary btn-sm" data-embed-copy>
            {locale === "sq" ? "Kopjo" : "Copy"}
          </button>
          <button type="button" class="share-btn" data-embed-close>
            {locale === "sq" ? "Mbyll" : "Close"}
          </button>
        </div>
      </div>
    </div>
  )
}

<script is:inline src="/js/share.js"></script>

<style>
  .share-row {
    margin: 1.5rem 0;
    padding: 1rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .share-row--compact {
    margin: 0;
    padding: 0;
    border: 0;
    display: inline-flex;
  }
  .share-row--compact .share-row-buttons {
    gap: 0.35rem;
  }
  .share-row--compact .share-btn {
    min-height: auto;
    padding: 0.15rem 0.4rem;
    font-size: 0.75rem;
    border: 0;
    background: transparent;
    color: var(--color-text-muted);
  }
  .share-row--compact .share-btn:hover {
    color: var(--color-link);
    background: transparent;
  }
  .share-row-label {
    display: block;
    margin-bottom: 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-secondary);
  }
  .share-row-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-dark);
    font-size: 0.875rem;
    font-weight: 600;
    font-family: inherit;
    text-decoration: none;
    cursor: pointer;
  }
  .share-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-link);
  }
  .share-btn-embed {
    font-family: ui-monospace, monospace;
  }
  .share-btn-native.hidden,
  .embed-popover.hidden {
    display: none;
  }
  .embed-popover {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .embed-popover-backdrop {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.45);
  }
  .embed-popover-panel {
    position: relative;
    z-index: 1;
    width: min(100%, 28rem);
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-card);
    padding: 1rem;
    box-shadow: 0 12px 40px rgb(0 0 0 / 0.15);
  }
  .embed-popover-title {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-dark);
  }
  .embed-popover-hint {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    color: var(--color-secondary);
  }
  .embed-popover-code {
    width: 100%;
    border-radius: 0.375rem;
    border: 1px solid var(--color-border);
    background: var(--color-page);
    padding: 0.75rem;
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    color: var(--color-dark);
    resize: vertical;
  }
  .embed-popover-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }
</style>
