---
import author from "../data/author.json";
import { localePath, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const profileHref = localePath(author.profileUrl, locale);
---

<span class="author-chip-compact">
  <a href={profileHref} class="author-chip-compact__avatar" aria-label={author.displayName}>
    <img
      src={author.photo}
      alt=""
      width="24"
      height="24"
      class="author-chip-compact__photo"
      loading="lazy"
    />
  </a>
  <a href={profileHref} class="author-chip-compact__name">{author.displayName}</a>
</span>

<style>
  .author-chip-compact {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: inherit;
  }

  .author-chip-compact__avatar {
    display: inline-flex;
    flex-shrink: 0;
  }

  .author-chip-compact__photo {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    object-fit: cover;
  }

  .author-chip-compact__name {
    color: var(--color-text);
    font-weight: 600;
    text-decoration: none;
  }

  .author-chip-compact__name:hover {
    color: var(--color-link);
  }
</style>
